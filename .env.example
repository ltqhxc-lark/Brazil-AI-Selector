# .env.example
# ---------------------------------------------------------------------------
# Brazil-AI-Selector 环境变量配置文件模板
# 使用方法：复制本文件为 `.env` 并填入你自己的密钥与配置
# 🚨 切勿将真实的 `.env` 文件提交至 Git 仓库！
# ---------------------------------------------------------------------------

# --- 1. 系统设置 ---
DEBUG=True
ENVIRONMENT=development  # development, staging, production

# --- 2. 大语言模型 API 密钥（用于 AI 选品分析） ---
# 支持 OpenAI, Gemini, Claude 等，根据后续接入需求配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- 3. 电商平台 API 认证（可选，后续根据对接方式调整） ---
# Mercado Livre 开发者账号配置
MERCADO_LIVRE_CLIENT_ID=your_ml_client_id
MERCADO_LIVRE_CLIENT_SECRET=your_ml_client_secret

# Shopee 开放平台配置
SHOPEE_PARTNER_ID=your_shopee_partner_id
SHOPEE_PARTNER_KEY=your_shopee_partner_key

# TikTok Shop 开放平台配置
TIKTOK_SHOP_APP_KEY=your_tts_app_key
TIKTOK_SHOP_APP_SECRET=your_tts_app_secret

# --- 4. 数据库配置 ---
# 默认使用本地 SQLite 数据库，后续如需扩展可配置 PostgreSQL/MySQL
DB_PATH=db/brazil_selector.db
